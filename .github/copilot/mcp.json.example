{
  "mcpServers": {
    "proxmox-mcp": {
      "command": "node",
      "args": ["dist/index.js"],
      "env": {
        "PROXMOX_HOST": "https://YOUR_PROXMOX_HOST:8006",
        "PROXMOX_TOKEN_ID": "mcp@pve!copilot",
        "PROXMOX_TOKEN_SECRET": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
        "PROXMOX_READ_ONLY": "true",
        "PROXMOX_ALLOW_SELF_SIGNED": "true"
      }
    }
  }
}
